# -----------------------------------------------
# LeetTok — Environment Variables
# -----------------------------------------------
# Copy this file to .env and fill in the values.
# The pipeline has its own .env.example in pipeline/.env.example.

# --- Supabase (Edge Function secrets) -----------
# Set these via `supabase secrets set` for deployed functions.
# SUPABASE_URL and SUPABASE_SERVICE_ROLE_KEY are auto-injected
# by the Supabase runtime, but you need to configure the others.
SUPABASE_SERVICE_ROLE_KEY=

# --- Google OAuth (Supabase Auth) ----------------
# Used by supabase/config.toml for Google social login.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- Code Execution (Judge0) ---------------------
# Powers the in-app code editor. Without these, code
# execution will not work. The free tier at ce.judge0.com
# works for development.
JUDGE0_URL=https://ce.judge0.com
JUDGE0_AUTH_TOKEN=

# --- AI Tutor (OpenAI) --------------------------
# Powers the AI tutor chat via the chat-tutor edge function.
OPENAI_API_KEY=
